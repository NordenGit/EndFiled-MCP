# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
**/dist/
*.tsbuildinfo

# Bundled game data — populated at build time by fetch-bundled-data.ts
# (or the CD pipeline), never committed. Only the .gitkeep placeholder
# and the directory structure are tracked.
ts/data/endfield/tables/
ts/data/endfield/i18n/
ts/data/endfield/archives/
ts/data/endfield/story/

# Runtime synced data (user data dir, never in repo)
/data/endfield/

# Local development scratch
# /dev/ is anchored to repo root so it does NOT match docs/dev/ (developer docs).
/dev/
scratch/
tmp/
*.log

# Test caches
.pytest_cache/
.bun-test-cache/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Env files (keep examples)
.env
.env.local
.mcp.json

# Release archives prepared locally
*.tar
